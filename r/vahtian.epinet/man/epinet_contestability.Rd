% Generated by hand; keep in sync with R/contestability.R.
\name{epinet_contestability}
\alias{epinet_contestability}
\alias{print.epinet_contestability}
\alias{summary.epinet_contestability}
\alias{plot.epinet_contestability}
\title{Score contestability against the outcome-class centroids}
\usage{
epinet_contestability(data, outcome, predictors = NULL,
  metric = "euclidean", contest_quantile = 0.1)

\method{print}{epinet_contestability}(x, ...)

\method{summary}{epinet_contestability}(object, ...)

\method{plot}{epinet_contestability}(x, top = 10L, ...)
}
\arguments{
\item{data}{A data frame: one row per subject.}

\item{outcome}{Name of the outcome (label) column.}

\item{predictors}{Character vector of predictor columns (default: all but
\code{outcome}). Non-numeric predictors are one-hot encoded.}

\item{metric}{Distance metric: \code{"euclidean"} (default) or
\code{"mahalanobis"}.}

\item{contest_quantile}{Fraction flagged as most contestable (default 0.1).}

\item{x, object}{An \code{"epinet_contestability"} object.}

\item{top}{Number of value-of-information features to show in \code{plot()}
(default 10).}

\item{...}{Unused.}
}
\value{
An object of class \code{"epinet_contestability"}: a list with per-row
\code{flip_distance} and \code{contested} vectors, the \code{contest_threshold},
a \code{flip_summary}, a \code{feature_voi} ranking, and the full
\code{assignments} table.
}
\description{
For every row, computes the closed-form flip-distance (how far it must move in
standardized feature space to flip its nearest-centroid class), the runner-up
class, and a per-feature value-of-information ranking. The lowest
\code{contest_quantile} of flip-distances are flagged as the most contestable.
\code{plot()} draws the contestability lens: the flip-distance distribution with
the contested tail shaded, beside the value-of-information ranking.

A research and education demonstrator, not clinical decision support.
}
\examples{
\dontrun{
cst <- epinet_contestability(data, outcome = "copd",
                             predictors = c("age", "sex", "smoking"))
summary(cst)
plot(cst)
}
}
