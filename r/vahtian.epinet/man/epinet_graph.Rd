% Generated by hand; keep in sync with R/graph.R.
\name{epinet_graph}
\alias{epinet_graph}
\alias{print.epinet_graph}
\alias{summary.epinet_graph}
\alias{plot.epinet_graph}
\title{Build a graph, derive graph features, and fit the outcome model}
\usage{
epinet_graph(nodes, edges, outcome, id_column = "ID",
  source_column = "SourceID", target_column = "TargetID",
  directed = FALSE, include_centrality = FALSE, n_iterations = 1L,
  n_bootstrap = 1000L, random_state = 42L)

\method{print}{epinet_graph}(x, ...)

\method{summary}{epinet_graph}(object, ...)

\method{plot}{epinet_graph}(x, ...)
}
\arguments{
\item{nodes}{A data frame of nodes (must include \code{id_column} and
\code{outcome}).}

\item{edges}{A data frame of edges (must include \code{source_column} and
\code{target_column}).}

\item{outcome}{Name of the outcome column in \code{nodes}.}

\item{id_column}{Node id column (default "ID").}

\item{source_column, target_column}{Edge endpoint columns (defaults
"SourceID"/"TargetID").}

\item{directed}{Treat edges as directed (default FALSE).}

\item{include_centrality}{Also compute betweenness/closeness/PageRank
(default FALSE; slower on large graphs).}

\item{n_iterations, n_bootstrap, random_state}{Passed to the outcome model.}

\item{x, object}{An \code{"epinet_graph"} object.}

\item{...}{Unused.}
}
\value{
An object of class \code{"epinet_graph"}: a list with \code{n_nodes},
\code{n_edges}, \code{metrics}, \code{importance}, \code{feature_columns}, and
the \code{nodes}/\code{edges} structure used for plotting.
}
\description{
Constructs the node/edge graph, computes graph features (degree, clustering,
component size, optional centrality), joins them with node attributes, and fits
EpiNet's honestly-evaluated outcome model. \code{plot()} draws the network
natively in R (coloured by outcome, sized by degree) using \pkg{igraph} when
available, otherwise a degree-distribution fallback.

A research and education demonstrator, not clinical decision support.
}
\examples{
\dontrun{
g <- epinet_graph(nodes, edges, outcome = "Outcome")
summary(g)
plot(g)
}
}
