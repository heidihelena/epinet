% Generated by hand; keep in sync with R/epinet.R.
\name{epinet}
\alias{epinet}
\alias{print.epinet}
\alias{summary.epinet}
\alias{plot.epinet}
\title{Fit EpiNet's honestly-evaluated outcome model on a data frame}
\usage{
epinet(data, outcome, predictors = NULL, n_iterations = 1L,
  n_permutations = 0L, n_bootstrap = 1000L, test_size = 0.2,
  random_state = 42L, tune_threshold = FALSE,
  model = c("random_forest", "logistic_regression", "xgboost"))

\method{print}{epinet}(x, ...)

\method{summary}{epinet}(object, ...)

\method{plot}{epinet}(x, top = 10L, ...)
}
\arguments{
\item{data}{A data frame: one row per subject.}

\item{outcome}{Name of the outcome (label) column.}

\item{predictors}{Character vector of predictor columns. Defaults to every
column except \code{outcome}.}

\item{n_iterations}{Number of repeated train/test splits (default 1).}

\item{n_permutations}{Label-permutation null draws; 0 disables (default 0).}

\item{n_bootstrap}{Bootstrap resamples for the primary-split interval; 0
disables (default 1000).}

\item{test_size}{Held-out fraction per split (default 0.2).}

\item{random_state}{Integer seed (default 42).}

\item{tune_threshold}{Tune the decision threshold on out-of-bag training
scores instead of 0.5 (binary outcomes; default FALSE).}

\item{model}{Primary estimator: \code{"random_forest"} (default),
\code{"logistic_regression"}, or \code{"xgboost"} (requires the Python
\code{xgboost} package).}

\item{x, object}{An \code{"epinet"} object.}

\item{top}{Number of top features to show in \code{plot()} (default 10).}

\item{...}{Unused.}
}
\value{
An object of class \code{"epinet"}: a list with \code{outcome},
\code{predictors}, \code{features_used}, \code{n}, \code{metrics}, and
\code{importance}.
}
\description{
Builds a design matrix from the named predictors (non-numeric predictors are
one-hot encoded) and fits EpiNet's outcome model with its honest-evaluation
defaults: imbalance-aware tuning, calibration, a percentile bootstrap
interval, an optional label-permutation null, and permutation feature
importance. The computation runs in the tested Python core via reticulate.

This is a research and education demonstrator, not clinical decision support.
}
\examples{
\dontrun{
fit <- epinet(data, outcome = "copd", predictors = c("age", "sex", "smoking"))
summary(fit)
plot(fit)
print(fit)
}
}
