% Generated by hand; keep in sync with R/federated.R.
\name{epinet_federated}
\alias{epinet_federated}
\alias{print.epinet_federated}
\alias{summary.epinet_federated}
\alias{plot.epinet_federated}
\title{Federate the fit across sites and check it reconstructs the centralized run}
\usage{
epinet_federated(data, outcome, predictors = NULL, site = NULL,
  n_sites = 2L, metric = "euclidean", contest_quantile = 0.1,
  random_state = 42L)

\method{print}{epinet_federated}(x, ...)

\method{summary}{epinet_federated}(object, ...)

\method{plot}{epinet_federated}(x, ...)
}
\arguments{
\item{data}{A data frame: one row per subject.}

\item{outcome}{Name of the outcome (label) column.}

\item{predictors}{Character vector of predictor columns (default: all but
\code{outcome} and, if used, \code{site}). Non-numeric predictors are one-hot
encoded.}

\item{site}{Optional column name giving each row's site. If \code{NULL}, rows
are split into \code{n_sites} random groups.}

\item{n_sites}{Number of synthetic sites when \code{site} is \code{NULL}
(default 2).}

\item{metric}{Distance metric for the contestability round-trip.}

\item{contest_quantile}{Contested fraction for the contestability round-trip.}

\item{random_state}{Integer seed for the random site split.}

\item{x, object}{An \code{"epinet_federated"} object.}

\item{...}{Unused.}
}
\value{
An object of class \code{"epinet_federated"}: a list with \code{n},
\code{n_sites}, per-site \code{sites} sizes, \code{fit_diffs} (max abs
mean/sd/centroid differences vs the centralized fit), and, when computable,
\code{contestability_diffs} plus \code{runner_up_match}/\code{top_voi_match}.
}
\description{
Partitions the rows across sites (by the \code{site} column if given, otherwise
into \code{n_sites} balanced random groups) and runs EpiNet's federated
reconstruction: only per-site aggregates cross, never rows. The reported
differences from the centralized fit should be at floating-point level,
demonstrating the federation is exact. \code{plot()} shows the per-site sizes
and the reconstruction error against the centralized run.

A research and education demonstrator, not clinical decision support.
}
\examples{
\dontrun{
fed <- epinet_federated(data, outcome = "copd",
                        predictors = c("age", "sex", "smoking"), n_sites = 3)
summary(fed)
plot(fed)
}
}
